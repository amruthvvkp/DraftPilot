# Copy to .env and adjust. docker compose reads .env automatically.

# --- Telemetry ----------------------------------------------------------------
# ON by default. compose.yml ships Logfire/OTLP traces to the in-stack Langfuse,
# which auto-provisions a dev project whose keys match the default auth header
# below — so `docker compose up` gives you working traces with no extra setup.
# Set OTEL__ENABLED=false to disable, or override the endpoint for external LGTM.
# OTEL__ENABLED=true

# OTLP/HTTP endpoint. Defaults to the in-stack Langfuse. Override for an external
# collector, e.g. Grafana LGTM: http://host.docker.internal:4318
# OTEL__EXPORTER_OTLP_ENDPOINT=http://langfuse-web:3000/api/public/otel

# Auth header. Default = Basic base64("pk-lf-draftpilot-dev:sk-lf-draftpilot-dev"),
# matching the LANGFUSE_INIT_* bootstrap keys. CHANGEME (re-base64 new keys) for
# non-local use, or when overriding the bootstrap keys below.
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64(public:secret)>

# --- Published host ports -----------------------------------------------------
# Container-internal ports are fixed; these only change what's exposed on the host.
# Postgres/Redis default OFF the standard ports so they don't clash with a local
# Postgres (5432) / Redis (6379) or your shared stack. Override as needed.
# DRAFTPILOT_POSTGRES_PORT=55432
# DRAFTPILOT_REDIS_PORT=56379
# DRAFTPILOT_UI_PORT=9000
# DRAFTPILOT_MCP_PORT=9001

# --- Debug ports (compose.dev.yml) --------------------------------------------
# DRAFTPILOT_UI_DEBUGPY_PORT=5678
# DRAFTPILOT_WORKER_DEBUGPY_PORT=5679

# --- Langfuse (part of the default stack, self-hosted) ------------------------
# Comes up with `docker compose up`. UI on :3300 (login dev@draftpilot.local /
# draftpilot-dev). REPLACE every secret below before any non-local use; if you
# change the project keys, also re-base64 them into OTEL_EXPORTER_OTLP_HEADERS.
# DRAFTPILOT_LANGFUSE_PORT=3300
# DRAFTPILOT_LANGFUSE_MINIO_PORT=9190
# DRAFTPILOT_LANGFUSE_MINIO_CONSOLE_PORT=9191
# LANGFUSE_SALT=                       # CHANGEME
# LANGFUSE_ENCRYPTION_KEY=             # CHANGEME: openssl rand -hex 32
# LANGFUSE_NEXTAUTH_SECRET=            # CHANGEME: openssl rand -base64 32
# LANGFUSE_POSTGRES_PASSWORD=          # CHANGEME
# LANGFUSE_CLICKHOUSE_PASSWORD=        # CHANGEME
# LANGFUSE_REDIS_AUTH=                 # CHANGEME
# LANGFUSE_MINIO_ROOT_PASSWORD=        # CHANGEME
# First-boot bootstrap (defaults already wired in compose.yml; override here):
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-draftpilot-dev
# LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-draftpilot-dev   # CHANGEME
# LANGFUSE_INIT_USER_EMAIL=dev@draftpilot.local
# LANGFUSE_INIT_USER_PASSWORD=draftpilot-dev              # CHANGEME
